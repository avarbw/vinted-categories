{
  "manifest_version": 3,
  "name": "Vinted Like Categories",
  "version": "1.0",
  "description": "Organise your Vinted likes into custom categories",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.vinted.co.uk/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}